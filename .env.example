# ===========================================
# Supabase + Prisma（本番で「Can't reach database server」を防ぐ設定）
# ===========================================
# 1. Supabase ダッシュボード → Project Settings → Database で接続文字列を確認
# 2. 本番（Vercel 等）では必ず「トランザクションモード Pooler」を DATABASE_URL に設定してください。
#    db.xxx.supabase.co:5432 の直接接続は Vercel から届かないことがあります。
#
# DATABASE_URL（アプリ・Prisma Client 用）
#   → Supabase の「Transaction pooler」の URI をコピーし、末尾に次を追加すること：
#      ?pgbouncer=true&sslmode=require
#   例（あなたのリージョンが ap-northeast-1 の場合）:
#     postgresql://postgres.hoaludyhjhcubewutqnk:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
#
# DIRECT_URL（Prisma Migrate 用）
#   → 直接接続（port 5432）または Session mode Pooler（port 5432）
#   例: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
#
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# NextAuth
AUTH_SECRET="..."
NEXTAUTH_URL="http://localhost:3002"

# その他（必要に応じて）
# OPENAI_API_KEY="..."
