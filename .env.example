# ===========================================
# 勤怠管理アプリ 環境変数サンプル
# Copy this file to .env and fill in the values.
# このファイルを .env にコピーし、値を設定してください。
# ===========================================

# Database (Supabase / Neon 等の PostgreSQL)
# プール用接続文字列（Vercel などでは必須）
DATABASE_URL="postgresql://user:password@host:5432/database?pgbouncer=true"

# マイグレーション・Prisma 用の直接接続URL
DIRECT_URL="postgresql://user:password@host:5432/database"

# NextAuth v5
# JWT 署名用シークレット（必須）。例: openssl rand -base64 32
AUTH_SECRET="your-32-char-or-longer-secret"

# 本番のアプリURL（Vercel では自動設定のため未設定で可）
# AUTH_URL="https://your-app.vercel.app"
