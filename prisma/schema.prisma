generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  password      String
  role          String        @default("member")
  attendance    Attendance[]
  leaveRequests LeaveRequest[]
  settings      UserSettings?
  quizAttempts  QuizAttempt[]
  activityLogs  ActivityLog[]
  createdAt     DateTime      @default(now())
}

/// ダッシュボード表示カスタマイズ・学習設定（ログインごとに反映）
model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  showSpecialDay      Boolean  @default(true)
  showAiNews          Boolean  @default(true)
  showAiTerm          Boolean  @default(true)
  displayMode         String   @default("standard")
  displayVolume       String   @default("simple") // "simple" | "detailed"
  preferredTopicIds   String?  // JSON array of topic ids
  customLearningGoal  String?  // 自由記述「TOEIC 800点を目指す」等 → LLM連携用
  dailyQuizCount      Int      @default(5)
  learningLevel       String   @default("intermediate") // beginner | intermediate | advanced | pro
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// 閲覧履歴（ニュース・トピック等）。パーソナライズ精度向上用
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  kind      String   // "news_view" | "topic_view" | "quiz_view"
  targetId  String?  // ニュースID・トピックID等
  metadata  String?  // JSON
  createdAt DateTime @default(now())
}

/// 忘却曲線に基づくクイズ回答履歴（復習タイミング計算に使用）
model QuizAttempt {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  questionId   String
  correct      Boolean
  answeredAt   DateTime @default(now())
  nextReviewAt DateTime? // エビングハウスに基づく次回出題日
  createdAt    DateTime @default(now())
}

model Attendance {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  date       String
  clockIn    String?
  clockOut   String?
  breakStart String?
  breakEnd   String?
  note       String?
  createdAt  DateTime @default(now())
}

model LeaveRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      String
  type      String
  createdAt DateTime @default(now())
}